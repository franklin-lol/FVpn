# ============================================================
# UniProxy Environment Configuration
# Copy to .env and fill in values before deploying
# ============================================================

# ── Panel ────────────────────────────────────────────────────
PANEL_PORT=2095
DOMAIN=your-domain.com

# ── TLS ──────────────────────────────────────────────────────
CERT_PATH=/etc/uniproxy/ssl/cert.pem
KEY_PATH=/etc/uniproxy/ssl/key.pem

# ── Security (CHANGE THESE) ──────────────────────────────────
MASTER_PASSWORD=changeme_use_openssl_rand_hex_16
JWT_SECRET=changeme_use_openssl_rand_hex_32
JWT_EXPIRE_MINUTES=1440

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/uniproxy.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://uniproxy:password@postgres:5432/uniproxy
DB_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=changeme_redis

# ── Proxy Cores ──────────────────────────────────────────────
XRAY_BIN=/usr/local/bin/xray
SINGBOX_BIN=/usr/local/bin/sing-box
XRAY_CONFIG=/etc/xray/config.json
SINGBOX_CONFIG=/etc/sing-box/config.json

# ── VLESS Reality Keys (auto-generated by install.sh) ────────
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=

# ── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_ADMIN_IDS=123456789,987654321

# ── Self-Healing ─────────────────────────────────────────────
HEALTH_CHECK_URL=http://www.gstatic.com/generate_204
HEALTH_CHECK_INTERVAL=300

# ── Backups ──────────────────────────────────────────────────
BACKUP_DIR=/data/backups
BACKUP_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── CORS (comma-separated origins, * = all) ──────────────────
CORS_ORIGINS=*
