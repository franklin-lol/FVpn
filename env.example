# =============================================================================
# FVpn — Environment Configuration
# =============================================================================
#
# LEGEND:
#   [AUTO]   Generated by install.sh — do NOT set manually unless migrating
#   [MANUAL] Must be filled in by you
#   [OPT]    Optional, has sane default
#
# If .env already exists, install.sh will NOT overwrite it.
# Only missing keys are appended.
# =============================================================================


# -----------------------------------------------------------------------------
# Panel
# -----------------------------------------------------------------------------
PANEL_PORT=2095                          # [OPT] Web panel port
DOMAIN=your-domain.com                   # [MANUAL] Your server's domain or IP


# -----------------------------------------------------------------------------
# TLS Certificates
# [AUTO] Paths set by install.sh based on certbot/self-signed result
# -----------------------------------------------------------------------------
CERT_PATH=/etc/fvpn/ssl/cert.pem
KEY_PATH=/etc/fvpn/ssl/key.pem


# -----------------------------------------------------------------------------
# Security
# [AUTO] Generated by install.sh via `openssl rand`
# WARNING: changing MASTER_PASSWORD after first start requires manual DB update
# WARNING: changing JWT_SECRET invalidates all existing sessions
# -----------------------------------------------------------------------------
MASTER_PASSWORD=                         # [AUTO] Initial admin password
JWT_SECRET=                              # [AUTO] 32-byte hex secret
JWT_EXPIRE_MINUTES=1440                  # [OPT]  Session lifetime (minutes)


# -----------------------------------------------------------------------------
# Database
# [OPT] SQLite is default (zero config). Switch to PostgreSQL for scale.
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:////data/fvpn.db
# PostgreSQL alternative:
# DATABASE_URL=postgresql+asyncpg://fvpn:password@postgres:5432/fvpn


# -----------------------------------------------------------------------------
# Redis
# [AUTO] Password generated by install.sh
# REDIS_URL must match the password below
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                          # [AUTO]
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/0  # [AUTO]


# -----------------------------------------------------------------------------
# CORS
# [OPT] Accepted formats:
#   *                            — allow all origins (default, dev-only)
#   https://app.example.com      — single origin
#   https://a.com,https://b.com  — comma-separated list
# -----------------------------------------------------------------------------
CORS_ORIGINS=*


# -----------------------------------------------------------------------------
# Proxy Cores
# [AUTO] Set by install.sh after binary installation
# -----------------------------------------------------------------------------
XRAY_BIN=/usr/local/bin/xray
SINGBOX_BIN=/usr/local/bin/sing-box
XRAY_CONFIG=/etc/xray/config.json
SINGBOX_CONFIG=/etc/sing-box/config.json


# -----------------------------------------------------------------------------
# VLESS Reality Keys
# [AUTO] Generated by install.sh via `xray x25519`
# -----------------------------------------------------------------------------
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=


# -----------------------------------------------------------------------------
# Telegram Bot
# [MANUAL] Get token from @BotFather
# TELEGRAM_ADMIN_IDS: comma-separated Telegram user IDs allowed to use the bot
#   Find your ID: message @userinfobot
# Leave TELEGRAM_TOKEN empty to disable the bot container
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_ADMIN_IDS=


# -----------------------------------------------------------------------------
# Self-Healing
# [OPT]
# -----------------------------------------------------------------------------
HEALTH_CHECK_URL=http://www.gstatic.com/generate_204
HEALTH_CHECK_INTERVAL=300


# -----------------------------------------------------------------------------
# Backups
# [OPT] BACKUP_S3_BUCKET — leave empty to disable S3 upload
# Requires AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY in environment
# -----------------------------------------------------------------------------
BACKUP_DIR=/data/backups
BACKUP_S3_BUCKET=
